+// one-click re-subscribe in case the click was a mistake.
+
+import { Link, useSearchParams } from 'react-router-dom';
+import { PageShell } from '../components/PageShell';
+
+export function JournalUnsubscribedPage() {
+  const [params] = useSearchParams();
+  const list = params.get('list');
+  const isProduct = list === 'product';
+
+  return (
+    <PageShell title="Unsubscribed · Floom">
+      <article
+        style={{
+          maxWidth: 520,
+          margin: '0 auto',
+          textAlign: 'center',
+          paddingTop: 40,
+        }}
+      >
+        <h1
+          style={{
+            fontSize: 32,
+            fontWeight: 700,
+            lineHeight: 1.2,
+            color: 'var(--ink)',
+            margin: '0 0 16px',
+            letterSpacing: '-0.01em',
+          }}
+        >
+          You're unsubscribed.
+        </h1>
+        <p
+          style={{
+            fontSize: 16,
+            lineHeight: 1.6,
+            color: 'var(--muted)',
+            margin: '0 0 32px',
+          }}
+        >
+          {isProduct
+            ? "You're off the Floom product waitlist. I won't email you again."
+            : "You're off the Floom journal list. I won't email you again."}
+        </p>
+        <p style={{ fontSize: 14, color: 'var(--muted)', margin: 0 }}>
+          Changed your mind?{' '}
+          <Link to="/journal" style={{ color: 'var(--ink)', textDecoration: 'underline' }}>
+            Resubscribe
+          </Link>
+          .
+        </p>
+      </article>
+    </PageShell>
+  );
+}

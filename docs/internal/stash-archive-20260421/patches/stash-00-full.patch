+// Registry of journal entries. Each entry exports a React component for its
+// long-form body plus frontmatter metadata for the index page, OG tags, and
+// RSS. Ordered newest-first. Adding an entry is a one-line import + one row.
+
+import type { ComponentType } from 'react';
+import { Week3 } from './week-3';
+
+export interface JournalEntry {
+  slug: string;
+  title: string;
+  tldr: string;
+  date: string;
+  week: number;
+  readingTime: string;
+  Body: ComponentType;
+}
+
+export const JOURNAL_ENTRIES: JournalEntry[] = [
+  {
+    slug: 'week-3',
+    title: 'Week 3 — raw notes from building Floom',
+    tldr:
+      "People don't want an AI CEO. They want AI to take over the things they do manually right now — and they're struggling because the space is ambiguous. That's the gap Floom is built for.",
+    date: '2026-04-17',
+    week: 3,
+    readingTime: '4 min',
+    Body: Week3,
+  },
+];
+
+export function getEntry(slug: string): JournalEntry | undefined {
+  return JOURNAL_ENTRIES.find((e) => e.slug === slug);
+}

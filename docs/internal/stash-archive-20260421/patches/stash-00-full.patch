diff --git a/apps/server/src/routes/journal.ts b/apps/server/src/routes/journal.ts
new file mode 100644
index 0000000..d565b35
--- /dev/null
+++ b/apps/server/src/routes/journal.ts
@@ -0,0 +1,237 @@
+// Journal: double-opt-in subscriber flow for the build-in-public log.
+//
+// Two lists (journal, product) live in one table, keyed by (email, list).
+// Subscription is double opt-in: POST /subscribe creates a pending row and
+// mails a confirmation link; GET /confirm?token=... flips confirmed_at.
+// Unsubscribe is one-click: GET /unsubscribe?token=... sets unsubscribed_at.
+//
+// The confirm / unsubscribe handlers 302 to SPA pages so the user ends up
+// on a branded success screen instead of a raw JSON body.
+
+import { Hono } from 'hono';
+import { z } from 'zod';
+import { createHash, randomBytes } from 'node:crypto';
+import { db } from '../db.js';
+import { sendEmail } from '../services/email.js';
+
+export const journalRouter = new Hono();
+
+db.exec(`
+  CREATE TABLE IF NOT EXISTS journal_subscribers (
+    id INTEGER PRIMARY KEY AUTOINCREMENT,
+    email TEXT NOT NULL,
+    list TEXT NOT NULL CHECK (list IN ('journal', 'product')),
+    token TEXT NOT NULL UNIQUE,
+    confirmed_at TEXT,
+    unsubscribed_at TEXT,
+    created_at TEXT NOT NULL DEFAULT (datetime('now')),
+    UNIQUE (email, list)
+  );
+  CREATE INDEX IF NOT EXISTS journal_subscribers_token_idx
+    ON journal_subscribers(token);
+  CREATE INDEX IF NOT EXISTS journal_subscribers_list_confirmed_idx
+    ON journal_subscribers(list, confirmed_at);
+`);
+
+const SubscribeBody = z.object({
+  email: z.string().email().max(320),
+  list: z.enum(['journal', 'product']).default('journal'),
+});
+
+// Rolling-window rate limit. 10 subscribe attempts per hour per IP hash.
+// Mirrors the feedback-route pattern so a single origin can't spray the
+// confirmation inbox of an arbitrary recipient.
+const RATE_LIMIT = 10;
+const WINDOW_MS = 60 * 60 * 1000;
+const buckets = new Map<string, number[]>();
+
+function hashIp(raw: string | null): string {
+  const salt = process.env.FLOOM_JOURNAL_SALT || 'floom-journal-v1';
+  return createHash('sha256').update(`${salt}:${raw || 'unknown'}`).digest('hex').slice(0, 32);
+}
+
+function rateLimitHit(key: string): boolean {
+  const now = Date.now();
+  const cutoff = now - WINDOW_MS;
+  const arr = (buckets.get(key) || []).filter((t) => t > cutoff);
+  if (arr.length >= RATE_LIMIT) {
+    buckets.set(key, arr);
+    return true;
+  }
+  arr.push(now);
+  buckets.set(key, arr);
+  return false;
+}
+
+function baseUrl(): string {
+  return (process.env.PUBLIC_URL || `http://localhost:${process.env.PORT || 3051}`).replace(/\/$/, '');
+}
+
+function newToken(): string {
+  return randomBytes(32).toString('hex');
+}
+
+interface SubscriberRow {
+  id: number;
+  email: string;
+  list: 'journal' | 'product';
+  token: string;
+  confirmed_at: string | null;
+  unsubscribed_at: string | null;
+}
+
+/**
+ * POST /api/journal/subscribe
+ * Body: { email, list? }  (list defaults to 'journal')
+ *
+ * Creates or refreshes a pending subscription. Always emits a fresh token
+ * and resends the confirmation email so a user who lost the first message
+ * can re-request it by submitting the form again. Returns ok:true either
+ * way — we never disclose whether an email already exists in the list.
+ */
+journalRouter.post('/subscribe', async (c) => {
+  const ipHeader =
+    c.req.header('x-forwarded-for') ||
+    c.req.header('x-real-ip') ||
+    'unknown';
+  const ipHash = hashIp(ipHeader.split(',')[0].trim());
+  if (rateLimitHit(ipHash)) {
+    return c.json(
+      { error: 'Too many attempts. Try again in an hour.', code: 'rate_limited' },
+      429,
+    );
+  }
+
+  let body: unknown;
+  try {
+    body = await c.req.json();
+  } catch {
+    return c.json({ error: 'Body must be JSON', code: 'invalid_body' }, 400);
+  }
+  const parsed = SubscribeBody.safeParse(body);
+  if (!parsed.success) {
+    return c.json(
+      { error: 'Invalid body shape', code: 'invalid_body', details: parsed.error.flatten() },
+      400,
+    );
+  }
+
+  const email = parsed.data.email.trim().toLowerCase();
+  const list = parsed.data.list;
+  const token = newToken();
+
+  const existing = db
+    .prepare('SELECT id, confirmed_at FROM journal_subscribers WHERE email = ? AND list = ?')
+    .get(email, list) as Pick<SubscriberRow, 'id' | 'confirmed_at'> | undefined;
+
+  if (existing) {
+    db.prepare(
+      `UPDATE journal_subscribers
+       SET token = ?, unsubscribed_at = NULL
+       WHERE id = ?`,
+    ).run(token, existing.id);
+  } else {
+    db.prepare(
+      `INSERT INTO journal_subscribers (email, list, token) VALUES (?, ?, ?)`,
+    ).run(email, list, token);
+  }
+
+  // Already-confirmed, still-subscribed users don't need a second confirm
+  // mail. Tell them nothing changed.
+  if (existing?.confirmed_at) {
+    return c.json({ ok: true, status: 'already_confirmed' });
+  }
+
+  const confirmUrl = `${baseUrl()}/api/journal/confirm?token=${token}`;
+  const subject =
+    list === 'journal'
+      ? 'Confirm your Floom journal subscription'
+      : 'Confirm your Floom waitlist signup';
+  const text =
+    list === 'journal'
+      ? `One click to confirm you want raw weekly notes from building Floom:
+
+${confirmUrl}
+
+If this wasn't you, ignore this email — you won't hear from me again.
+
+— Federico`
+      : `One click to confirm you want to be on the Floom waitlist:
+
+${confirmUrl}
+
+If this wasn't you, ignore this email — you won't hear from me again.
+
+— Federico`;
+
+  const result = await sendEmail({ to: email, subject, text });
+  if (!result.ok) {
+    return c.json(
+      { error: 'Could not send confirmation email', code: 'email_failed' },
+      502,
+    );
+  }
+
+  return c.json({ ok: true, status: 'pending_confirmation', transport: result.transport });
+});
+
+/**
+ * GET /api/journal/confirm?token=...
+ * Flips confirmed_at to now() and redirects the browser to the SPA success
+ * page. Used from the link in the confirmation email, so returning JSON
+ * would be a worse UX than a redirect even if the token is invalid.
+ */
+journalRouter.get('/confirm', (c) => {
+  const token = c.req.query('token');
+  if (!token || typeof token !== 'string') {
+    return c.redirect('/journal?confirm=invalid', 302);
+  }
+
+  const row = db
+    .prepare(
+      `UPDATE journal_subscribers
+         SET confirmed_at = COALESCE(confirmed_at, datetime('now')),
+             unsubscribed_at = NULL
+       WHERE token = ?
+       RETURNING list`,
+    )
+    .get(token) as { list: 'journal' | 'product' } | undefined;
+
+  if (!row) {
+    return c.redirect('/journal?confirm=invalid', 302);
+  }
+  return c.redirect(`/journal/confirmed?list=${row.list}`, 302);
+});
+
+/**
+ * GET /api/journal/unsubscribe?token=...
+ * One-click unsubscribe. GDPR + Gmail List-Unsubscribe both expect an
+ * HTTP GET that works without JavaScript or a second confirmation.
+ */
+journalRouter.get('/unsubscribe', (c) => {
+  const token = c.req.query('token');
+  if (!token || typeof token !== 'string') {
+    return c.redirect('/journal?unsubscribe=invalid', 302);
+  }
+
+  const row = db
+    .prepare(
+      `UPDATE journal_subscribers
+         SET unsubscribed_at = datetime('now')
+       WHERE token = ?
+       RETURNING list`,
+    )
+    .get(token) as { list: 'journal' | 'product' } | undefined;
+
+  if (!row) {
+    return c.redirect('/journal?unsubscribe=invalid', 302);
+  }
+  return c.redirect(`/journal/unsubscribed?list=${row.list}`, 302);
+});
+
+/**
+ * Reset in-memory rate-limit bucket. Tests only.
+ */
+export function _resetJournalBucketsForTests(): void {
+  buckets.clear();
+}
diff --git a/apps/server/src/services/email.ts b/apps/server/src/services/email.ts
new file mode 100644
index 0000000..2f0ed8a
--- /dev/null
+++ b/apps/server/src/services/email.ts
@@ -0,0 +1,54 @@
+// Unified email sender. Uses Resend when RESEND_API_KEY is set; otherwise
+// logs the outgoing email to stdout so OSS self-hosters and dev environments
+// still see confirmation URLs without needing an email provider.
+//
+// Resend is imported dynamically so the package only loads when actually
+// configured — the OSS image can skip installing it entirely if we ever move
+// it to an optional dep.
+
+interface SendEmailArgs {
+  to: string;
+  subject: string;
+  text: string;
+  from?: string;
+}
+
+interface SendEmailResult {
+  ok: boolean;
+  id?: string;
+  transport: 'resend' | 'stdout';
+  error?: string;
+}
+
+const DEFAULT_FROM = process.env.FLOOM_JOURNAL_FROM || 'Floom <journal@floom.dev>';
+
+export async function sendEmail({
+  to,
+  subject,
+  text,
+  from = DEFAULT_FROM,
+}: SendEmailArgs): Promise<SendEmailResult> {
+  const apiKey = process.env.RESEND_API_KEY;
+  if (!apiKey) {
+    // Dev / OSS fallback: log full email so operator can copy links.
+    console.log(
+      `[email:stdout] to=${to} from=${from} subject="${subject}"\n-----\n${text}\n-----`,
+    );
+    return { ok: true, transport: 'stdout' };
+  }
+
+  try {
+    const { Resend } = await import('resend');
+    const client = new Resend(apiKey);
+    const res = await client.emails.send({ from, to, subject, text });
+    if (res.error) {
+      console.error('[email:resend] send failed', res.error);
+      return { ok: false, transport: 'resend', error: String(res.error.message) };
+    }
+    return { ok: true, id: res.data?.id, transport: 'resend' };
+  } catch (err) {
+    const msg = err instanceof Error ? err.message : String(err);
+    console.error('[email:resend] threw', msg);
+    return { ok: false, transport: 'resend', error: msg };
+  }
+}

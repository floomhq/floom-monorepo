index 0000000..641e87d
--- /dev/null
+++ b/apps/web/src/components/JournalSubscribeForm.tsx
@@ -0,0 +1,114 @@
+import { useState } from 'react';
+import * as api from '../api/client';
+
+interface Props {
+  list?: 'journal' | 'product';
+  placeholder?: string;
+  ctaLabel?: string;
+}
+
+// Email capture for the journal / product waitlist. Handles three states
+// (idle, pending, error) and surfaces a post-submit message telling the
+// user to check their inbox. No analytics hooks — keep it thin.
+export function JournalSubscribeForm({
+  list = 'journal',
+  placeholder = 'you@work.com',
+  ctaLabel = 'Subscribe',
+}: Props) {
+  const [email, setEmail] = useState('');
+  const [state, setState] = useState<'idle' | 'loading' | 'done' | 'error'>('idle');
+  const [message, setMessage] = useState<string | null>(null);
+
+  async function onSubmit(e: React.FormEvent) {
+    e.preventDefault();
+    if (state === 'loading') return;
+    setState('loading');
+    setMessage(null);
+    try {
+      const res = await api.subscribeJournal(email.trim(), list);
+      if (res.status === 'already_confirmed') {
+        setState('done');
+        setMessage("You're already subscribed. Thanks.");
+      } else {
+        setState('done');
+        setMessage('Check your inbox — one click to confirm.');
+      }
+    } catch (err) {
+      setState('error');
+      setMessage(
+        err instanceof Error && err.message ? err.message : 'Something went wrong. Try again.',
+      );
+    }
+  }
+
+  if (state === 'done') {
+    return (
+      <p style={{ fontSize: 14, color: 'var(--muted)', margin: 0 }} role="status">
+        {message}
+      </p>
+    );
+  }
+
+  return (
+    <form
+      onSubmit={onSubmit}
+      style={{
+        display: 'flex',
+        gap: 8,
+        flexWrap: 'wrap',
+        maxWidth: 480,
+      }}
+    >
+      <input
+        type="email"
+        required
+        value={email}
+        onChange={(e) => setEmail(e.target.value)}
+        placeholder={placeholder}
+        aria-label="Email address"
+        style={{
+          flex: '1 1 220px',
+          padding: '10px 14px',
+          fontSize: 14,
+          fontFamily: 'inherit',
+          color: 'var(--ink)',
+          background: 'var(--card)',
+          border: '1px solid var(--line)',
+          borderRadius: 999,
+          outline: 'none',
+        }}
+      />
+      <button
+        type="submit"
+        disabled={state === 'loading'}
+        style={{
+          padding: '10px 18px',
+          fontSize: 14,
+          fontWeight: 600,
+          fontFamily: 'inherit',
+          color: '#fff',
+          background: 'var(--ink)',
+          border: '1px solid var(--ink)',
+          borderRadius: 999,
+          cursor: state === 'loading' ? 'wait' : 'pointer',
+          opacity: state === 'loading' ? 0.6 : 1,
+        }}
+      >
+        {state === 'loading' ? 'Sending…' : ctaLabel}
+      </button>
+      {state === 'error' && message && (
+        <p
+          style={{
+            flex: '1 1 100%',
+            fontSize: 13,
+            color: '#b91c1c',
+            margin: '4px 0 0',
+          }}
+          role="alert"
+        >
+          {message}
+        </p>
+      )}
+    </form>
+  );
+}

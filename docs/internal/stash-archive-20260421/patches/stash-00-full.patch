diff --git a/apps/web/src/pages/JournalEntryPage.tsx b/apps/web/src/pages/JournalEntryPage.tsx
new file mode 100644
index 0000000..8fe12e2
--- /dev/null
+++ b/apps/web/src/pages/JournalEntryPage.tsx
@@ -0,0 +1,134 @@
+// /journal/:slug — individual journal entry. 404s through NotFoundPage's
+// component when the slug isn't in the registry. Entry bodies are plain
+// React components; the wrapper supplies the editorial typography via a
+// shared `.journal-article` class (see styles/globals.css additions).
+
+import { Link, Navigate, useParams } from 'react-router-dom';
+import { useEffect } from 'react';
+import { PageShell } from '../components/PageShell';
+import { JournalSubscribeForm } from '../components/JournalSubscribeForm';
+import { getEntry } from '../content/journal';
+
+function formatDate(iso: string): string {
+  return new Date(iso).toLocaleDateString('en-US', {
+    month: 'long',
+    day: 'numeric',
+    year: 'numeric',
+  });
+}
+
+export function JournalEntryPage() {
+  const { slug } = useParams<{ slug: string }>();
+  const entry = slug ? getEntry(slug) : undefined;
+
+  useEffect(() => {
+    if (entry) {
+      // Minimal OG/SEO hints for crawlers that execute JS. Full server-side
+      // OG is a follow-up (needs an HTML meta inject in the Hono SPA
+      // fallback or a prerender step).
+      const meta = document.querySelector<HTMLMetaElement>('meta[name="description"]');
+      if (meta) meta.content = entry.tldr;
+    }
+  }, [entry]);
+
+  if (!slug) return <Navigate to="/journal" replace />;
+  if (!entry) return <Navigate to="/journal" replace />;
+
+  const { Body } = entry;
+
+  return (
+    <PageShell title={`${entry.title} · Floom Journal`}>
+      <article
+        className="journal-article"
+        style={{
+          maxWidth: 640,
+          margin: '0 auto',
+        }}
+      >
+        <nav style={{ marginBottom: 24 }}>
+          <Link
+            to="/journal"
+            style={{
+              fontSize: 13,
+              color: 'var(--muted)',
+              textDecoration: 'none',
+            }}
+          >
+            ← All entries
+          </Link>
+        </nav>
+
+        <header style={{ marginBottom: 40 }}>
+          <div
+            style={{
+              display: 'flex',
+              gap: 12,
+              fontSize: 13,
+              color: 'var(--muted)',
+              marginBottom: 12,
+            }}
+          >
+            <span
+              style={{
+                fontFamily:
+                  'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
+                fontSize: 12,
+              }}
+            >
+              Week {entry.week}
+            </span>
+            <span>·</span>
+            <time dateTime={entry.date}>{formatDate(entry.date)}</time>
+            <span>·</span>
+            <span>{entry.readingTime}</span>
+          </div>
+          <h1
+            style={{
+              fontSize: 36,
+              fontWeight: 700,
+              lineHeight: 1.2,
+              color: 'var(--ink)',
+              margin: '0 0 20px',
+              letterSpacing: '-0.01em',
+            }}
+          >
+            {entry.title}
+          </h1>
+          <p
+            style={{
+              fontSize: 19,
+              lineHeight: 1.55,
+              color: 'var(--muted)',
+              margin: 0,
+            }}
+          >
+            {entry.tldr}
+          </p>
+        </header>
+
+        <div className="journal-article-body">
+          <Body />
+        </div>
+
+        <footer
+          style={{
+            marginTop: 64,
+            paddingTop: 32,
+            borderTop: '1px solid var(--line)',
+          }}
+        >
+          <p
+            style={{
+              fontSize: 14,
+              color: 'var(--muted)',
+              margin: '0 0 16px',
+            }}
+          >
+            Next entry drops Friday. Get it in your inbox.
+          </p>
+          <JournalSubscribeForm list="journal" />
+        </footer>
+      </article>
+    </PageShell>
+  );
+}
diff --git a/apps/web/src/pages/JournalPage.tsx b/apps/web/src/pages/JournalPage.tsx
new file mode 100644

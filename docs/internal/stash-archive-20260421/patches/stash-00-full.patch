@@ -0,0 +1,164 @@
+// /journal — build-in-public index. Lists every entry newest-first and
+// captures emails via the shared JournalSubscribeForm. Kept deliberately
+// plain: one column, editorial typography, no hero image, no CMS.
+
+import { Link, useSearchParams } from 'react-router-dom';
+import { PageShell } from '../components/PageShell';
+import { JournalSubscribeForm } from '../components/JournalSubscribeForm';
+import { JOURNAL_ENTRIES } from '../content/journal';
+
+function formatDate(iso: string): string {
+  return new Date(iso).toLocaleDateString('en-US', {
+    month: 'long',
+    day: 'numeric',
+    year: 'numeric',
+  });
+}
+
+export function JournalPage() {
+  const [params] = useSearchParams();
+  const confirmState = params.get('confirm');
+  const unsubscribeState = params.get('unsubscribe');
+
+  return (
+    <PageShell title="Journal · Floom">
+      <article
+        style={{
+          maxWidth: 640,
+          margin: '0 auto',
+        }}
+      >
+        {(confirmState === 'invalid' || unsubscribeState === 'invalid') && (
+          <div
+            role="alert"
+            style={{
+              padding: '12px 16px',
+              marginBottom: 24,
+              background: 'rgba(185, 28, 28, 0.06)',
+              border: '1px solid rgba(185, 28, 28, 0.2)',
+              borderRadius: 8,
+              fontSize: 14,
+              color: '#7f1d1d',
+            }}
+          >
+            That link has already been used or has expired. Enter your email
+            again to get a fresh one.
+          </div>
+        )}
+
+        <header style={{ marginBottom: 48 }}>
+          <p
+            style={{
+              fontSize: 12,
+              letterSpacing: '0.12em',
+              textTransform: 'uppercase',
+              color: 'var(--muted)',
+              margin: '0 0 12px',
+            }}
+          >
+            Journal
+          </p>
+          <h1
+            style={{
+              fontSize: 40,
+              fontWeight: 700,
+              lineHeight: 1.15,
+              color: 'var(--ink)',
+              margin: '0 0 16px',
+              letterSpacing: '-0.01em',
+            }}
+          >
+            Building Floom, in the open.
+          </h1>
+          <p
+            style={{
+              fontSize: 17,
+              lineHeight: 1.6,
+              color: 'var(--muted)',
+              margin: '0 0 24px',
+              maxWidth: 560,
+            }}
+          >
+            Weekly notes. Raw, unedited, shipped every Friday. The metrics,
+            the conversations, the things that didn't work.
+          </p>
+          <JournalSubscribeForm list="journal" />
+        </header>
+
+        <ol
+          style={{
+            listStyle: 'none',
+            padding: 0,
+            margin: 0,
+            borderTop: '1px solid var(--line)',
+          }}
+        >
+          {JOURNAL_ENTRIES.map((entry) => (
+            <li
+              key={entry.slug}
+              style={{
+                padding: '28px 0',
+                borderBottom: '1px solid var(--line)',
+              }}
+            >
+              <Link
+                to={`/journal/${entry.slug}`}
+                style={{
+                  display: 'block',
+                  textDecoration: 'none',
+                  color: 'inherit',
+                }}
+              >
+                <div
+                  style={{
+                    display: 'flex',
+                    gap: 12,
+                    fontSize: 13,
+                    color: 'var(--muted)',
+                    marginBottom: 8,
+                  }}
+                >
+                  <span
+                    style={{
+                      fontFamily:
+                        'ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace',
+                      fontSize: 12,
+                    }}
+                  >
+                    Week {entry.week}
+                  </span>
+                  <span>·</span>
+                  <time dateTime={entry.date}>{formatDate(entry.date)}</time>
+                  <span>·</span>
+                  <span>{entry.readingTime}</span>
+                </div>
+                <h2
+                  style={{
+                    fontSize: 24,
+                    fontWeight: 700,
+                    lineHeight: 1.25,
+                    color: 'var(--ink)',
+                    margin: '0 0 8px',
+                    letterSpacing: '-0.005em',
+                  }}
+                >
+                  {entry.title}
+                </h2>
+                <p
+                  style={{
+                    fontSize: 15,
+                    lineHeight: 1.55,
+                    color: 'var(--muted)',
+                    margin: 0,
+                  }}
+                >
+                  {entry.tldr}
+                </p>
+              </Link>
+            </li>
+          ))}
+        </ol>
+      </article>
+    </PageShell>
+  );
+}

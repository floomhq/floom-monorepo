+<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" role="img" aria-label="Floom">
+  <!--
+    Floom mark with halo. Green gradient mark + SVG filter glow on a
+    transparent background. Use for hero moments (onboarding, 404 echo,
+    large brand surfaces). The filter composites a tight halo + a far
+    halo, both color-pinned to brand green via feFlood, so the glow
+    stays on brand regardless of where the SVG is placed.
+  -->
+  <defs>
+    <linearGradient id="floom-mark-gradient" x1="0" y1="0" x2="1" y2="1">
+      <stop offset="0" stop-color="#059669"/>
+      <stop offset="1" stop-color="#10b981"/>
+    </linearGradient>
+    <filter id="floom-glow" x="-60%" y="-60%" width="220%" height="220%">
+      <feGaussianBlur in="SourceAlpha" stdDeviation="3" result="tight"/>
+      <feFlood flood-color="#10b981" flood-opacity="0.55" result="tight-color"/>
+      <feComposite in="tight-color" in2="tight" operator="in" result="tight-halo"/>
+      <feGaussianBlur in="SourceAlpha" stdDeviation="10" result="far"/>
+      <feFlood flood-color="#059669" flood-opacity="0.35" result="far-color"/>
+      <feComposite in="far-color" in2="far" operator="in" result="far-halo"/>
+      <feMerge>
+        <feMergeNode in="far-halo"/>
+        <feMergeNode in="tight-halo"/>
+        <feMergeNode in="SourceGraphic"/>
+      </feMerge>
+    </filter>
+  </defs>
+  <path
+    d="M32 26 h20 l22 22 a3 3 0 0 1 0 4 l-22 22 h-20 a6 6 0 0 1 -6 -6 v-36 a6 6 0 0 1 6 -6 z"
+    fill="url(#floom-mark-gradient)"
+    filter="url(#floom-glow)"
+  />
+</svg>

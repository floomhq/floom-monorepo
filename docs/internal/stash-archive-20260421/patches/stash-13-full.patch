+<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" role="img" aria-label="Floom">
+  <!--
+    Floom mark. Flat green on transparent. Used for the tab favicon and
+    inline contexts where SVG filters won't render crisp at small sizes.
+    Shape: rounded-square left half + chevron extending right, reads as
+    a forward/play arrow. 100x100 viewBox, single <path> for crisp edges.
+  -->
+  <defs>
+    <linearGradient id="flat" x1="0" y1="0" x2="1" y2="1">
+      <stop offset="0" stop-color="#059669"/>
+      <stop offset="1" stop-color="#10b981"/>
+    </linearGradient>
+  </defs>
+  <path
+    d="M32 26 h20 l22 22 a3 3 0 0 1 0 4 l-22 22 h-20 a6 6 0 0 1 -6 -6 v-36 a6 6 0 0 1 6 -6 z"
+    fill="url(#flat)"
+  />
+</svg>

@@ -0,0 +1,49 @@
+<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 180 180" role="img" aria-label="Floom">
+  <!--
+    Floom app icon. iOS-style rounded square with a soft dark gradient,
+    green mark with a baked halo, subtle inner highlight at the top edge.
+    This is the source for apple-touch-icon (180x180) and the maskable
+    PWA icon (512x512). Corner radius 22% matches the iOS icon template.
+  -->
+  <defs>
+    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
+      <stop offset="0" stop-color="#121218"/>
+      <stop offset="1" stop-color="#08080C"/>
+    </linearGradient>
+    <linearGradient id="mark" x1="0" y1="0" x2="1" y2="1">
+      <stop offset="0" stop-color="#059669"/>
+      <stop offset="1" stop-color="#10b981"/>
+    </linearGradient>
+    <filter id="halo" x="-60%" y="-60%" width="220%" height="220%">
+      <feGaussianBlur in="SourceAlpha" stdDeviation="5" result="tight"/>
+      <feFlood flood-color="#10b981" flood-opacity="0.60" result="tight-color"/>
+      <feComposite in="tight-color" in2="tight" operator="in" result="tight-halo"/>
+      <feGaussianBlur in="SourceAlpha" stdDeviation="16" result="far"/>
+      <feFlood flood-color="#059669" flood-opacity="0.45" result="far-color"/>
+      <feComposite in="far-color" in2="far" operator="in" result="far-halo"/>
+      <feMerge>
+        <feMergeNode in="far-halo"/>
+        <feMergeNode in="tight-halo"/>
+        <feMergeNode in="SourceGraphic"/>
+      </feMerge>
+    </filter>
+  </defs>
+  <!-- background -->
+  <rect x="0" y="0" width="180" height="180" rx="40" ry="40" fill="url(#bg)"/>
+  <!-- subtle top highlight (iOS icon depth) -->
+  <rect x="0" y="0" width="180" height="180" rx="40" ry="40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
+  <!--
+    Mark is defined in a 100x100 coord space. Scale 1.4 places it at
+    140x140 inside the 180x180 frame, then translate (180-140)/2 = 20
+    on each axis so the mark sits centered. The path's actual ink
+    extents within that 100 frame are ~26..76 so the optical centering
+    is near-perfect.
+  -->
+  <g transform="translate(20, 20) scale(1.4)">
+    <path
+      d="M32 26 h20 l22 22 a3 3 0 0 1 0 4 l-22 22 h-20 a6 6 0 0 1 -6 -6 v-36 a6 6 0 0 1 6 -6 z"
+      fill="url(#mark)"
+      filter="url(#halo)"
+    />
+  </g>
+</svg>

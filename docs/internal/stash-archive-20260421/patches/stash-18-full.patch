+.codeblock-tab:hover:not(.is-active) {
+  color: #d4d2c8;
+}
+.codeblock-copy {
+  display: inline-flex;
+  align-items: center;
+  gap: 5px;
+  padding: 6px 10px;
+  font-size: 11px;
+  background: rgba(255, 255, 255, 0.05);
+  border: 1px solid #2a2a22;
+  border-radius: 7px;
+  color: rgba(241, 239, 233, 0.7);
+  cursor: pointer;
+  font-family: inherit;
+}
+.codeblock-copy:hover {
+  color: #f1efe9;
+}
+.codeblock-body {
+  margin: 0;
+  padding: 18px 20px;
+  font-family: 'JetBrains Mono', monospace;
+  font-size: 13px;
+  line-height: 1.7;
+  color: #d4d2c8;
+  overflow-x: auto;
+}
+.codeblock-body code {
+  font-family: inherit;
+}
+.tk-key { color: #9f96ff; }
+.tk-str { color: #c5e898; }
+.tk-num { color: #ffcb8b; }
+.tk-bool { color: #ff9a8b; }

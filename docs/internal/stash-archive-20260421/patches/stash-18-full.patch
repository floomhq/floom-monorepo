+  border-radius: 7px;
+  color: var(--muted);
+  cursor: pointer;
+  font-family: inherit;
+}
+.demo-replay:hover {
+  color: var(--ink);
+}
+.demo-body {
+  padding: 20px 22px 22px;
+}
+.demo-prompt {
+  display: flex;
+  align-items: center;
+  gap: 10px;
+  padding: 10px 12px;

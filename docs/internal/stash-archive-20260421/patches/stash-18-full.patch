+/* ── Hero ───────────────────────────────────────────────────────────── */
+.home-hero {
+  position: relative;
+  border-bottom: 1px solid var(--line);
+  padding: 96px 24px 80px;
+  overflow: hidden;
+}
+.home-hero::before {
+  content: '';
+  position: absolute;
+  inset: 0;
+  background:
+    radial-gradient(circle at 20% 20%, rgba(61, 43, 255, 0.07) 0%, transparent 45%),
+    radial-gradient(circle at 80% 30%, rgba(61, 43, 255, 0.04) 0%, transparent 45%);
+  pointer-events: none;
+}
+.home-hero-inner {
+  position: relative;
+  max-width: 880px;
+  margin: 0 auto;
+  text-align: center;
+}
+.home-hero-eyebrow {
+  display: inline-flex;
+  align-items: center;
+  gap: 8px;
+  padding: 5px 11px;
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 999px;

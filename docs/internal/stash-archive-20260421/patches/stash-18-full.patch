+}
+.home-btn-secondary:hover {
+  border-color: var(--ink);
+}
+.home-btn-ghost {
+  background: none;
+  color: var(--muted);
+}
+.home-btn-ghost:hover {
+  color: var(--ink);
+}
+
+/* hero stats row */
+.home-hero-stats {
+  display: flex;
+  justify-content: center;
+  gap: 48px;

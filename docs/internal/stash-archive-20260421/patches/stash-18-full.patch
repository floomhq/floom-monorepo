+/* ═══════════════════════════════════════════════════════════════════════
+   Home page rebuild — dense, product-first, supabase-density.
+   All classes scoped under .home-* or component-specific roots so they
+   don't bleed into the rest of the app. Uses the existing CSS variables
+   (--bg, --ink, --muted, --line, --card, --accent, --terminal-bg).
+   ═══════════════════════════════════════════════════════════════════════ */
+
+.home-section {
+  border-bottom: 1px solid var(--line);
+  padding: 72px 24px;
+}
+.home-section.is-dark {
+  background: linear-gradient(180deg, #0c0c0a 0%, #14140f 100%);
+  color: #f1efe9;
+  border-top: 1px solid #1f1f1a;
+  border-bottom: 1px solid #1f1f1a;
+}
+.home-section-inner {
+  max-width: 1080px;
+  margin: 0 auto;
+}
+.home-section-narrow {
+  max-width: 760px;
+  margin: 0 auto;
+}
+.home-section-head {
+  display: flex;
+  flex-direction: column;
+  gap: 8px;
+  margin-bottom: 36px;
+  max-width: 640px;
+}
+.home-section-head.is-center {
+  margin-left: auto;
+  margin-right: auto;

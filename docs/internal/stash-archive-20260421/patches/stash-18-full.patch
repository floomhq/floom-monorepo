+}
+.home-hero-stat {
+  display: flex;
+  flex-direction: column;
+  gap: 4px;
+}
+.home-hero-stat-num {
+  font-size: 22px;
+  font-weight: 700;
+  color: var(--ink);
+  font-feature-settings: 'tnum';
+}
+.home-hero-stat-label {
+  font-size: 12px;
+  color: var(--muted);
+  font-family: 'JetBrains Mono', monospace;
+}
+
+/* ── Launch apps strip ─────────────────────────────────────────────── */
+.launch-strip {
+  padding: 36px 24px;
+  border-bottom: 1px solid var(--line);
+  background: var(--card);
+}
+.launch-strip-head {
+  max-width: 1080px;
+  margin: 0 auto 16px;
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+}
+.launch-strip-all {

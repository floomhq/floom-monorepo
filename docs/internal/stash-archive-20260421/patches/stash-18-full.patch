+/* ── Self-host terminal (beat 4) ───────────────────────────────────── */
+.terminal {
+  background: #0e0e0c;
+  border: 1px solid #1f1f1a;
+  border-radius: 12px;
+  overflow: hidden;
+  box-shadow: 0 12px 40px -20px rgba(0, 0, 0, 0.6);
+}
+.terminal-head {
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 9px 12px;
+  background: #141410;
+  border-bottom: 1px solid #1f1f1a;
+}
+.terminal-traffic {
+  display: flex;
+  gap: 6px;
+}
+.terminal-traffic span {
+  width: 11px;
+  height: 11px;
+  border-radius: 50%;
+  background: #2a2a22;
+}
+.terminal-traffic span:nth-child(1) { background: #ff5f57; }
+.terminal-traffic span:nth-child(2) { background: #febc2e; }
+.terminal-traffic span:nth-child(3) { background: #28c840; }
+.terminal-title {
+  flex: 1;
+  text-align: center;
+  font-size: 11px;
+  color: rgba(241, 239, 233, 0.5);
+  font-family: 'JetBrains Mono', monospace;
+}
+.terminal-body {
+  margin: 0;
+  padding: 18px 20px 22px;
+  font-family: 'JetBrains Mono', monospace;
+  font-size: 12.5px;
+  line-height: 1.65;
+  color: #d4d2c8;
+  overflow-x: auto;
+  min-height: 360px;
+}
+.terminal-body .term-cmd { color: #f1efe9; font-weight: 600; }
+.terminal-body .term-out { color: #d4d2c8; }
+.terminal-body .term-dim { color: #6e6c64; }
+.terminal-body .term-info { color: #9f96ff; }
+.terminal-body .term-ok { color: #c5e898; }
+.terminal-body .term-ready {
+  color: #28c840;
+  font-weight: 700;
+  margin-top: 4px;
+}
+.term-cursor {
+  display: inline-block;
+  color: #c5e898;
+  animation: term-blink 1s steps(2) infinite;
+}
+@keyframes term-blink {
+  50% { opacity: 0; }
+}
+

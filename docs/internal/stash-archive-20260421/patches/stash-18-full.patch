+/* ── Code block (beat 3: plug into your agent) ─────────────────────── */
+.codeblock {
+  background: #0e0e0c;
+  border: 1px solid #1f1f1a;
+  border-radius: 12px;
+  overflow: hidden;
+}
+.codeblock-head {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  padding: 8px 10px;
+  border-bottom: 1px solid #1f1f1a;
+  background: #141410;
+}
+.codeblock-tabs {
+  display: flex;
+  gap: 2px;
+}
+.codeblock-tab {
+  padding: 6px 12px;
+  font-size: 12px;
+  background: none;
+  border: 1px solid transparent;
+  border-radius: 7px;
+  color: rgba(241, 239, 233, 0.55);
+  cursor: pointer;
+  font-family: inherit;

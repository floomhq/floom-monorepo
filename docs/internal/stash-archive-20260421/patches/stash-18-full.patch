+}
+.flight-card-arrow {
+  color: var(--muted);
+  display: inline-flex;
+}
+.flight-card-price {
+  font-size: 16px;
+  font-weight: 700;
+  color: var(--ink);
+  font-feature-settings: 'tnum';
+}
+.flight-card-meta {
+  font-size: 11.5px;
+  color: var(--muted);
+  font-family: 'JetBrains Mono', monospace;
+}
+.flight-card-date {
+  font-size: 11.5px;
+  color: var(--muted);
+  font-family: 'JetBrains Mono', monospace;
+}
+
+.blast-output {
+  padding: 12px 14px;
+  background: #fafaf8;
+  border: 1px solid var(--line);
+  border-radius: 9px;
+}
+.blast-summary {

+  padding: 18px 18px;
+  display: flex;
+  align-items: flex-start;
+  gap: 12px;
+  min-height: 96px;
+}
+.roadmap-cell-icon {
+  width: 28px;
+  height: 28px;
+  border-radius: 7px;
+  background: var(--accent-soft);
+  color: var(--accent);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  flex-shrink: 0;
+}
+.roadmap-cell-text { display: flex; flex-direction: column; gap: 3px; }
+.roadmap-cell-label {
+  margin: 0;
+  font-size: 13px;
+  font-weight: 700;
+  color: var(--ink);
+}
+.roadmap-cell-desc {

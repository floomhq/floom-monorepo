+}
+.launch-cell:hover {
+  background: #f6f5ef;
+}
+.launch-cell-name {
+  font-size: 13px;
+  font-weight: 700;
+  color: var(--ink);
+}
+.launch-cell-tagline {
+  font-size: 11px;
+  color: var(--muted);
+  line-height: 1.4;
+  flex: 1;
+}
+.launch-cell-tag {
+  font-size: 10px;
+  color: var(--muted);
+  font-family: 'JetBrains Mono', monospace;
+  text-transform: lowercase;
+}
+
+/* ── Surfaces diagram (beat 1) ─────────────────────────────────────── */
+.surfaces-wrap {
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 14px;
+  padding: 40px;
+  position: relative;
+  overflow: hidden;
+}
+.surfaces-wrap::after {
+  content: '';
+  position: absolute;
+  inset: 0;
+  background: radial-gradient(circle at 50% 0%, rgba(61, 43, 255, 0.04), transparent 60%);
+  pointer-events: none;
+}
+.surfaces-diagram {
+  position: relative;
+  display: grid;
+  grid-template-columns: 220px 1fr;
+  gap: 0;
+  align-items: center;
+  min-height: 320px;
+}
+.surfaces-spec {
+  position: relative;
+  z-index: 2;
+  display: flex;
+  align-items: center;
+  gap: 12px;
+  padding: 16px 18px;
+  background: var(--ink);
+  border-radius: 12px;
+  color: #f7f5ee;
+  box-shadow: 0 8px 24px -12px rgba(14, 14, 12, 0.35);
+  width: fit-content;
+}
+.surfaces-spec-icon {
+  width: 32px;
+  height: 32px;
+  border-radius: 8px;
+  background: rgba(255, 255, 255, 0.08);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+  color: #d4cefa;
+}
+.surfaces-spec-label {
+  margin: 0;
+  font-size: 13px;
+  font-weight: 700;
+  font-family: 'JetBrains Mono', monospace;
+}
+.surfaces-spec-meta {
+  margin: 0;
+  font-size: 11px;
+  color: rgba(255, 255, 255, 0.55);
+  font-family: 'JetBrains Mono', monospace;
+}
+.surfaces-lines {
+  position: absolute;
+  left: 200px;
+  top: 50%;
+  transform: translateY(-50%);
+  width: calc(100% - 200px);
+  height: 240px;
+  z-index: 0;
+  pointer-events: none;
+}
+.surfaces-nodes {
+  position: relative;
+  z-index: 1;
+  display: grid;
+  grid-template-columns: 1fr 1fr;
+  gap: 16px;
+  margin-left: auto;
+  max-width: 480px;
+}
+.surface-node {
+  background: #fafaf8;
+  border: 1px solid var(--line);
+  border-radius: 10px;
+  padding: 14px 16px;
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+  transition: border-color 0.15s, transform 0.15s;
+}
+.surface-node:hover {
+  border-color: var(--accent);
+  transform: translateY(-1px);
+}
+.surface-node-head {
+  display: flex;
+  align-items: center;
+  gap: 8px;
+}
+.surface-node-icon {
+  width: 22px;
+  height: 22px;
+  border-radius: 6px;
+  background: var(--accent-soft);
+  color: var(--accent);
+  display: flex;
+  align-items: center;
+  justify-content: center;
+}
+.surface-node-label {
+  font-size: 13px;
+  font-weight: 700;
+  color: var(--ink);
+}
+.surface-node-desc {
+  margin: 0;
+  font-size: 11.5px;
+  line-height: 1.5;
+  color: var(--muted);
+}
+
+@media (max-width: 760px) {
+  .surfaces-wrap { padding: 24px; }
+  .surfaces-diagram {
+    grid-template-columns: 1fr;
+    gap: 24px;
+    min-height: auto;
+  }
+  .surfaces-lines { display: none; }
+  .surfaces-nodes { margin-left: 0; max-width: 100%; }
+}
+
+/* ── Inline app demo (beat 2) ──────────────────────────────────────── */
+.demo-wrap {
+  background: var(--card);
+  border: 1px solid var(--line);
+  border-radius: 14px;
+  overflow: hidden;

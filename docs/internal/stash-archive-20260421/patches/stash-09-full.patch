new file mode 100644
index 0000000..2a655b9
--- /dev/null
+++ b/apps/web/src/lib/consent.ts
@@ -0,0 +1,93 @@
+// Cookie consent storage. Single source of truth for read/write/subscribe.
+// Used by `CookieBanner` (UI) and `lib/sentry.ts` (gate). Kept tiny and
+// SSR-safe so `initBrowserSentry` can be called from `main.tsx` at boot
+// without pulling in React.
+//
+// Storage layout (kept in sync, both written together in `setConsent`):
+//   - localStorage["floom.cookie-consent"] = "essential" | "all"
+//   - document.cookie  "floom.cookie-consent" = same value, 1 year, Lax
+//
+// We mirror to a first-party cookie so any future server-rendered routes
+// can respect the choice without waiting for client JS.
+
+export type Consent = 'essential' | 'all';
+
+export const CONSENT_STORAGE_KEY = 'floom.cookie-consent';
+export const CONSENT_COOKIE_NAME = 'floom.cookie-consent';
+const COOKIE_MAX_AGE = 60 * 60 * 24 * 365;
+
+const REOPEN_EVENT = 'floom:open-cookie-settings';
+const CHANGE_EVENT = 'floom:cookie-consent-change';
+
+export function getConsent(): Consent | null {
+  if (typeof window === 'undefined') return null;
+  try {
+    const v = window.localStorage.getItem(CONSENT_STORAGE_KEY);
+    if (v === 'essential' || v === 'all') return v;
+  } catch {
+    // localStorage can throw in private mode; fall through to cookie.
+  }
+  if (typeof document !== 'undefined') {
+    const match = document.cookie.match(
+      new RegExp('(?:^|; )' + CONSENT_COOKIE_NAME.replace(/\./g, '\\.') + '=([^;]+)'),
+    );
+    if (match && (match[1] === 'essential' || match[1] === 'all')) {
+      return match[1] as Consent;
+    }
+  }
+  return null;
+}
+
+export function setConsent(choice: Consent): void {
+  if (typeof window === 'undefined') return;
+  try {
+    window.localStorage.setItem(CONSENT_STORAGE_KEY, choice);
+  } catch {
+    // ignore (private mode)
+  }
+  try {
+    const secure = window.location.protocol === 'https:' ? '; Secure' : '';
+    document.cookie =
+      `${CONSENT_COOKIE_NAME}=${choice}; Max-Age=${COOKIE_MAX_AGE}; Path=/; SameSite=Lax${secure}`;
+  } catch {
+    // ignore
+  }
+  try {
+    window.dispatchEvent(new CustomEvent(CHANGE_EVENT, { detail: choice }));
+  } catch {
+    // ignore (older browsers)
+  }
+}
+
+/**
+ * Subscribe to consent changes. Returns an unsubscribe function. Useful for
+ * components that want to react to a user toggling their choice mid-session
+ * (e.g. footer "Cookie settings" → banner → new choice).
+ */
+export function subscribeConsent(fn: (next: Consent | null) => void): () => void {
+  if (typeof window === 'undefined') return () => {};
+  const handler = () => fn(getConsent());
+  window.addEventListener(CHANGE_EVENT, handler);
+  return () => window.removeEventListener(CHANGE_EVENT, handler);
+}
+
+/**
+ * Re-open the cookie banner so the user can change their choice. Implemented
+ * as a CustomEvent the banner listens for, so callers (e.g. footer button)
+ * don't need a ref to the banner instance.
+ */
+export function openCookieSettings(): void {
+  if (typeof window === 'undefined') return;
+  try {
+    window.dispatchEvent(new CustomEvent(REOPEN_EVENT));
+  } catch {
+    // ignore
+  }
+}
+
+/** Internal: banner subscribes to know when the footer button was clicked. */
+export function subscribeOpenCookieSettings(fn: () => void): () => void {
+  if (typeof window === 'undefined') return () => {};
+  window.addEventListener(REOPEN_EVENT, fn);
+  return () => window.removeEventListener(REOPEN_EVENT, fn);
+}
diff --git a/apps/web/src/lib/jobs.ts b/apps/web/src/lib/jobs.ts
new file mode 100644
index 0000000..63b5b9a
--- /dev/null
+++ b/apps/web/src/lib/jobs.ts
@@ -0,0 +1,48 @@
+// Helpers for the v0.3.0 async job queue surface.
+//
+// `jobToRunRecord` is the adapter that lets a terminal JobRecord render
+// through the existing OutputPanel without a parallel UI surface. The
+// adapter lives here (not inside FloomApp) so that callers which deep-link
+// straight into a finished job — namely AppPermalinkPage handling
+// /p/:slug?job=<id> — can hydrate without depending on FloomApp internals.
+
+import type { JobRecord, RunRecord } from './types';
+
+/**
+ * Convert a terminal JobRecord into a RunRecord so the existing OutputPanel
+ * can render succeeded/failed/cancelled jobs without a parallel UI. The
+ * job queue stores its results in the runs table under the hood, but the
+ * job poll endpoint returns a Job shape; this adapter preserves the
+ * existing output-card improvements (CopyButton, markdown-primary, HTML
+ * download, share-URL, error hints) without duplicating them.
+ */
+export function jobToRunRecord(job: JobRecord, action: string): RunRecord {
+  const ok = job.status === 'succeeded';
+  const startedAt = job.started_at || job.created_at;
+  const finishedAt = job.finished_at;
+  const duration =
+    startedAt && finishedAt
+      ? new Date(finishedAt).getTime() - new Date(startedAt).getTime()
+      : null;
+  const errorText =
+    job.error == null
+      ? null
+      : typeof job.error === 'string'
+        ? job.error
+        : JSON.stringify(job.error);
+  return {
+    id: job.run_id || job.id,
+    app_id: job.app_id,
+    thread_id: null,
+    action,
+    inputs: job.input,
+    outputs: job.output,
+    status: ok ? 'success' : 'error',
+    error: errorText,
+    error_type: ok ? null : job.status === 'cancelled' ? 'cancelled' : 'runtime_error',
+    duration_ms: duration,
+    started_at: startedAt,
+    finished_at: finishedAt,
+    logs: '',
+  };
+}
diff --git a/apps/web/src/lib/sentry.ts b/apps/web/src/lib/sentry.ts

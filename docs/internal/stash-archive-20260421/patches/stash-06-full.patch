diff --git a/apps/web/src/components/me/MeComposer.tsx b/apps/web/src/components/me/MeComposer.tsx
new file mode 100644
index 0000000..f0effbc
--- /dev/null
+++ b/apps/web/src/components/me/MeComposer.tsx
@@ -0,0 +1,147 @@
+// v15.1 /me composer. Renders the inline textarea + send button that
+// sits at the bottom of the right pane. We don't have a real threads
+// schema yet, so "sending" a follow-up just deep-links to the existing
+// run page for the target app with `?prompt=<text>` — the run page
+// (MeAppRunPage) reads the query param and prefills the first input.
+//
+// When there's no target app (the user has no apps installed), the
+// composer renders disabled with a hint that points to /apps or /build.
+
+import { useCallback, useEffect, useImperativeHandle, useRef, forwardRef, useState } from 'react';
+import { useNavigate } from 'react-router-dom';
+
+export interface MeComposerHandle {
+  focus: () => void;
+}
+
+interface Props {
+  /**
+   * The app slug the composer should route to. When null/undefined, the
+   * composer renders in a disabled "pick or build an app" state.
+   */
+  targetSlug: string | null;
+  /** Display name of the target app — used in the placeholder copy. */
+  targetName?: string | null;
+}
+
+export const MeComposer = forwardRef<MeComposerHandle, Props>(function MeComposer(
+  { targetSlug, targetName },
+  ref,
+) {
+  const navigate = useNavigate();
+  const textareaRef = useRef<HTMLTextAreaElement>(null);
+  const [value, setValue] = useState('');
+
+  useImperativeHandle(ref, () => ({
+    focus: () => textareaRef.current?.focus(),
+  }));
+
+  useEffect(() => {
+    // Autosize: cap at 140px to match the wireframe composer.
+    const el = textareaRef.current;
+    if (!el) return;
+    el.style.height = 'auto';
+    el.style.height = Math.min(140, el.scrollHeight) + 'px';
+  }, [value]);
+
+  const disabled = !targetSlug;
+
+  const submit = useCallback(() => {
+    if (disabled || !targetSlug) return;
+    const trimmed = value.trim();
+    const qs = trimmed ? `?prompt=${encodeURIComponent(trimmed)}` : '';
+    navigate(`/me/a/${targetSlug}/run${qs}`);
+  }, [disabled, targetSlug, value, navigate]);
+
+  return (
+    <form
+      data-testid="me-composer"
+      onSubmit={(e) => {
+        e.preventDefault();
+        submit();
+      }}
+      style={{
+        margin: '14px 24px 22px',
+        background: disabled ? 'var(--bg)' : 'var(--card)',
+        border: '1px solid var(--line)',
+        borderRadius: 14,
+        padding: '4px 4px 4px 16px',
+        display: 'flex',
+        alignItems: 'flex-end',
+        gap: 8,
+        boxShadow: disabled ? 'none' : '0 4px 14px rgba(15,23,42,.04)',
+      }}
+    >
+      <textarea
+        ref={textareaRef}
+        data-testid="me-composer-input"
+        rows={1}
+        value={value}
+        onChange={(e) => setValue(e.target.value)}
+        onKeyDown={(e) => {
+          if (e.key === 'Enter' && !e.shiftKey) {
+            e.preventDefault();
+            submit();
+          }
+        }}
+        disabled={disabled}
+        placeholder={
+          disabled
+            ? 'Pick or build an app to start a thread…'
+            : targetName
+              ? `Ask ${targetName} a follow-up…`
+              : 'Ask a follow-up…'
+        }
+        style={{
+          flex: 1,
+          border: 0,
+          outline: 'none',
+          resize: 'none',
+          background: 'transparent',
+          fontFamily: 'inherit',
+          fontSize: 14,
+          lineHeight: 1.5,
+          color: 'var(--ink)',
+          padding: '11px 0',
+          minHeight: 22,
+          maxHeight: 140,
+        }}
+      />
+      <button
+        type="submit"
+        data-testid="me-composer-send"
+        disabled={disabled || value.trim().length === 0}
+        aria-label="Send"
+        style={{
+          width: 32,
+          height: 32,
+          borderRadius: 9,
+          background: disabled || value.trim().length === 0 ? 'var(--line)' : 'var(--ink)',
+          color: '#fff',
+          display: 'flex',
+          alignItems: 'center',
+          justifyContent: 'center',
+          border: 0,
+          cursor: disabled || value.trim().length === 0 ? 'not-allowed' : 'pointer',
+          flexShrink: 0,
+          marginBottom: 5,
+          marginRight: 5,
+        }}
+      >
+        <svg
+          width="16"
+          height="16"
+          viewBox="0 0 24 24"
+          fill="none"
+          stroke="currentColor"
+          strokeWidth="1.75"
+          strokeLinecap="round"
+          strokeLinejoin="round"
+          aria-hidden="true"
+        >
+          <path d="M5 12h14M12 5l7 7-7 7" />
+        </svg>
+      </button>
+    </form>
+  );
+});
diff --git a/apps/web/src/components/me/MeMobile.tsx b/apps/web/src/components/me/MeMobile.tsx

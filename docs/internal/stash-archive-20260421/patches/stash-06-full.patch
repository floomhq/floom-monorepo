+// v15.1 /me right pane. Renders the "latest thread" (really: a single
+// run) in a Claude/ChatGPT turn-by-turn shape — a user turn with the
+// prompt followed by an app turn with the run's result summary. A
+// composer is mounted below via MeComposer (rendered by MePage so the
+// pane can stay presentational).
+//
+// Scope: single-turn only. Real multi-turn chat requires a threads
+// schema; for now the "Open in full →" link drops the user into the
+// existing run detail page where they can iterate.
+
+import { Link } from 'react-router-dom';
+import { AppIcon } from '../AppIcon';
+import { threadTitle } from '../../lib/thread';
+import type { MeRunDetail, MeRunSummary, RunStatus } from '../../lib/types';
+
+interface Props {
+  /** Thread summary used for the pane header / title. */
+  thread: MeRunSummary;
+  /**
+   * Full run record. Optional: while the detail is loading we still render
+   * the header from the summary and show a light-weight placeholder in the
+   * turn body. When null, the fetch failed and we surface an error.
+   */
+  detail: MeRunDetail | null;
+  detailError?: string | null;
+  appVisibility?: 'private' | 'public' | 'unlisted' | 'auth-required' | 'invite-only' | null;
+}
+
+export function MeThreadPane({ thread, detail, detailError, appVisibility }: Props) {
+  const slug = thread.app_slug;
+  const appName = thread.app_name || slug || 'App';
+  const title = threadTitle(thread);
+
+  return (
+    <section
+      data-testid="me-thread-pane"
+      style={{
+        background: 'var(--card)',
+        display: 'flex',
+        flexDirection: 'column',
+        height: '100vh',
+        minHeight: 560,
+        flex: 1,
+        minWidth: 0,
+      }}
+    >
+      <header
+        style={{
+          display: 'flex',
+          alignItems: 'center',
+          gap: 14,
+          padding: '14px 24px',
+          borderBottom: '1px solid var(--line)',
+        }}
+      >
+        <span
+          style={{
+            width: 26,
+            height: 26,
+            borderRadius: 7,
+            background: 'var(--bg)',
+            border: '1px solid var(--line)',
+            display: 'inline-flex',
+            alignItems: 'center',
+            justifyContent: 'center',
+            flexShrink: 0,
+          }}
+        >
+          {slug ? <AppIcon slug={slug} size={14} /> : null}
+        </span>
+        <span style={{ fontWeight: 600, fontSize: 14.5, color: 'var(--ink)' }}>
+          {appName}
+        </span>
+        {appVisibility === 'private' && (
+          <span
+            style={{
+              fontSize: 10.5,
+              padding: '2px 8px',
+              borderRadius: 999,
+              background: '#f1f5f9',
+              color: 'var(--muted)',
+              border: '1px solid var(--line)',
+              fontWeight: 600,
+              display: 'inline-flex',
+              alignItems: 'center',
+              gap: 4,
+            }}
+          >
+            <svg
+              width="10"
+              height="10"
+              viewBox="0 0 24 24"
+              fill="none"
+              stroke="currentColor"
+              strokeWidth="1.75"
+              aria-hidden="true"
+            >
+              <rect x="3" y="11" width="18" height="11" rx="2" />
+              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
+            </svg>
+            private
+          </span>
+        )}
+        <span
+          style={{
+            fontSize: 12.5,
+            color: 'var(--muted)',
+            marginLeft: 8,
+            overflow: 'hidden',
+            textOverflow: 'ellipsis',
+            whiteSpace: 'nowrap',
+            flex: 1,
+            minWidth: 0,
+          }}
+        >
+          {title}
+        </span>
+        <Link
+          to={slug ? `/me/runs/${thread.id}` : '#'}
+          data-testid="me-thread-open-full"
+          style={{
+            fontSize: 12.5,
+            color: 'var(--muted)',
+            textDecoration: 'none',
+            fontWeight: 500,
+            flexShrink: 0,
+            padding: '4px 8px',
+          }}
+        >
+          Open in full →
+        </Link>
+      </header>
+
+      <div style={{ flex: 1, overflowY: 'auto' }} data-testid="me-thread-body">
+        <div style={{ padding: '18px 24px' }}>
+          <TurnRow
+            role="user"
+            content={<span>{title}</span>}
+          />
+          <div style={{ height: 14 }} />
+          {detailError ? (
+            <ErrorBanner message={detailError} />
+          ) : detail ? (
+            <TurnRow
+              role="app"
+              content={<AppTurnBody run={detail} />}

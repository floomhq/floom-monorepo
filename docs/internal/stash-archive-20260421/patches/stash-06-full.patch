+        )}
+      </div>
+      <div
+        style={{
+          flex: 1,
+          minWidth: 0,
+          fontSize: 14.5,
+          color: 'var(--ink)',
+          paddingTop: 3,
+          lineHeight: 1.55,
+        }}
+      >
+        {content}
+      </div>
+    </div>
+  );
+}
+
+function AppTurnBody({ run }: { run: MeRunDetail }) {
+  const summary = buildSummaryText(run);
+  const statusColor = statusToColor(run.status);
+  const durationLabel =
+    typeof run.duration_ms === 'number' && run.duration_ms > 0
+      ? formatDuration(run.duration_ms)
+      : null;
+
+  return (
+    <>
+      <div
+        style={{
+          display: 'flex',
+          alignItems: 'center',
+          gap: 8,
+          marginBottom: 8,
+          fontSize: 11,
+          color: 'var(--muted)',
+          fontFamily: 'JetBrains Mono, monospace',
+          letterSpacing: '0.04em',
+        }}
+      >
+        <span
+          style={{
+            display: 'inline-block',
+            width: 5,
+            height: 5,
+            borderRadius: 999,
+            background: statusColor,
+          }}
+        />
+        <span>
+          {run.status}
+          {durationLabel ? ` · ${durationLabel}` : ''}
+          {run.action && run.action !== 'run' ? ` · ${run.action}` : ''}
+          {` · ${run.id.slice(0, 8)}`}
+        </span>
+      </div>
+      {summary ? (
+        <p
+          style={{
+            fontSize: 14,
+            color: 'var(--muted)',
+            margin: '0 0 10px',
+            lineHeight: 1.55,
+            whiteSpace: 'pre-wrap',
+            wordBreak: 'break-word',
+          }}
+        >
+          {summary}
+        </p>
+      ) : null}
+      {run.status === 'error' && run.error && (
+        <ErrorBanner message={run.error} />
+      )}
+    </>
+  );
+}
+
+function ErrorBanner({ message }: { message: string }) {
+  return (
+    <div
+      style={{
+        background: '#fdecea',
+        border: '1px solid #f4b7b1',
+        color: '#c2321f',
+        padding: '10px 14px',
+        borderRadius: 8,
+        fontSize: 13,
+      }}
+    >
+      {message}
+    </div>
+  );
+}
+
+function statusToColor(status: RunStatus | string): string {
+  switch (status) {
+    case 'success':
+      return 'var(--accent)';
+    case 'error':
+    case 'timeout':
+      return '#c2321f';
+    case 'running':
+    case 'pending':
+    default:
+      return 'var(--muted)';
+  }
+}
+
+function formatDuration(ms: number): string {
+  if (ms < 1000) return `${Math.round(ms)}ms`;
+  const seconds = ms / 1000;
+  if (seconds < 60) return `${seconds.toFixed(seconds < 10 ? 1 : 0)}s`;
+  const mins = Math.floor(seconds / 60);
+  const remSec = Math.round(seconds - mins * 60);
+  return `${mins}m ${remSec}s`;
+}
+
+function buildSummaryText(run: MeRunDetail): string {
+  const outputs = run.outputs;
+  if (outputs && typeof outputs === 'object') {
+    const record = outputs as Record<string, unknown>;
+    for (const key of ['summary', 'text', 'result', 'output', 'message']) {
+      const v = record[key];
+      if (typeof v === 'string' && v.trim()) {
+        return truncate(v.trim(), 600);
+      }
+    }
+    try {
+      const preview = JSON.stringify(outputs, null, 2);
+      return truncate(preview, 600);
+    } catch {
+      // fall through
+    }
+  } else if (typeof outputs === 'string' && outputs.trim()) {
+    return truncate(outputs.trim(), 600);
+  }
+  if (run.status === 'running' || run.status === 'pending') {
+    return 'Run in progress…';
+  }
+  return '';
+}
+
+function truncate(text: string, max: number): string {
+  return text.length <= max ? text : text.slice(0, max - 1).trimEnd() + '…';
+}

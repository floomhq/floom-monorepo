+    { text: '{"name":"floom","apps":15,"ok":true}', indent: 2 },
+  ),
+  'jwt-decode': buildSpec(
+    'jwt-decode',
+    'JWT Decoder',
+    'Decode a JWT header and payload without verifying the signature. Useful for inspecting claims, expiry, and algorithm during debugging.',
+    'decode',
+    {
+      type: 'object',
+      required: ['token'],
+      properties: {

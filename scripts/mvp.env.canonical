# Canonical env for floom-mvp-preview (mvp.floom.dev)
#
# This file is the SOURCE OF TRUTH for non-secret env on the MVP container.
# Secret values are referenced as ${VAR_NAME} — the redeploy script reads
# the actual secret values from the running container's env (or from the
# operator's shell) and merges them in. Canonical values here win on
# conflict for non-secret keys.
#
# WHY THIS EXISTS: FLOOM_CLOUD_MODE=1 was lost from the live container
# three times during R7 agent rebuilds because each ad-hoc `docker run`
# omitted it. Locking it in here + enforcing scripts/redeploy-mvp.sh as
# the single redeploy path means it cannot drift again.
#
# Format: KEY=VALUE — one per line. Lines starting with # are comments.
# Empty values are explicit ("KEY=" means "set to empty string").
#
# Last verified against live container: 2026-04-28
# Container: floom-mvp-preview, host port 127.0.0.1:3057 -> 3000

# --- mode flags (NON-SECRET, locked) ---
NODE_ENV=production
PORT=3000
FLOOM_CLOUD_MODE=1
DEPLOY_ENABLED=true
NEXT_PUBLIC_WAITLIST_MODE=false
FLOOM_SEED_APPS=false
FLOOM_SEED_LAUNCH_DEMOS=false
FLOOM_LAUNCH_WEEK_APPS=true
FLOOM_ENABLE_DOCKER_PUBLISH=false

# --- public URLs (NON-SECRET) ---
PUBLIC_URL=https://mvp.floom.dev
BETTER_AUTH_URL=https://mvp.floom.dev
CANONICAL_ORIGIN=https://mvp.floom.dev

# --- paths inside container (NON-SECRET) ---
DATA_DIR=/data
FLOOM_APPS_CONFIG=/apps/catalog/apps.yaml
FLOOM_FILE_INPUTS_DIR=/floom-file-inputs
FLOOM_FILE_INPUTS_HOST_DIR=/opt/floom-launch-file-inputs

# --- runner config (NON-SECRET) ---
RUNNER_TIMEOUT=300000
RUNNER_MEMORY=512m
RUNNER_CPUS=1
BUILD_TIMEOUT=600000
FLOOM_TRUSTED_PROXY_CIDRS=172.16.0.0/12

# --- model selection (NON-SECRET) ---
PARSER_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small

# --- email sender (NON-SECRET) ---
# DO NOT REVERT to noreply@. Federico 2026-04-29: Yahoo + Outlook spam-foldered
# every email when From: noreply@. Switched to team@ for ~10-15% deliverability
# lift (industry data on bulk-mail filters' weight on the noreply pattern).
RESEND_FROM=Floom <team@send.floom.dev>

# --- feedback → GitHub (NON-SECRET — repo only; token is below) ---
FEEDBACK_GITHUB_REPO=floomhq/floom

# --- OAuth public IDs (NON-SECRET — Google/GitHub treat client IDs as public) ---
GOOGLE_OAUTH_CLIENT_ID=1040922256467-nountmq1j8s9jd3b4edj4stg97l96th6.apps.googleusercontent.com
GITHUB_OAUTH_CLIENT_ID=${GITHUB_OAUTH_CLIENT_ID}

# --- error reporting (server-side; client uses VITE_SENTRY_WEB_DSN at build) ---
SENTRY_SERVER_DSN=https://0c640f4db88a428519f9868f8ff5f124@o4511300722229248.ingest.us.sentry.io/4511300733108224
SENTRY_DSN=https://0c640f4db88a428519f9868f8ff5f124@o4511300722229248.ingest.us.sentry.io/4511300733108224
SENTRY_ENVIRONMENT=mvp

# --- analytics (PostHog US cloud — Federico project ID 395246) ---
# Project token starts phc_ — write-only, safe in public bundles. The
# VITE_POSTHOG_* twins are baked into the web bundle at docker-build time
# (see docker/Dockerfile ARG VITE_POSTHOG_KEY).
POSTHOG_PROJECT_API_KEY=${POSTHOG_PROJECT_API_KEY}
POSTHOG_HOST=https://us.i.posthog.com

# --- GitHub OAuth — public client id (secret in shell env passthrough) ---
# Federico's OAuth app "Floom", callback https://floom.dev/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=${GITHUB_OAUTH_CLIENT_ID}

# --- bearer gate (NON-SECRET when empty; if set, becomes a SECRET) ---
FLOOM_AUTH_TOKEN=

# === SECRETS (referenced; actual values pulled from live container env or operator shell) ===
# The redeploy script pulls these from the existing container's env. If
# the container is gone, set them in the shell before running the script.
BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET}
OPENAI_API_KEY=${OPENAI_API_KEY}
GEMINI_API_KEY=${GEMINI_API_KEY}
APIFY_API_KEY=${APIFY_API_KEY}
RESEND_API_KEY=${RESEND_API_KEY}
GOOGLE_OAUTH_CLIENT_SECRET=${GOOGLE_OAUTH_CLIENT_SECRET}
GITHUB_OAUTH_CLIENT_SECRET=${GITHUB_OAUTH_CLIENT_SECRET}
FEEDBACK_GITHUB_TOKEN=${FEEDBACK_GITHUB_TOKEN}
FLOOM_REGISTRY_AUTH=${FLOOM_REGISTRY_AUTH}
COMPOSIO_API_KEY=${COMPOSIO_API_KEY}

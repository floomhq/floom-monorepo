# Canonical env for prod (floom.dev) — floom-prod-waitlist on :3055.
# Secrets are pulled from the live container by redeploy-prod.sh; this file
# only declares NON-secret keys + secret placeholders.
#
# Why this file exists: prod previously drifted because each ad-hoc
# `docker run` set env piecemeal. After 2026-04-29 OOM event we standardized
# on the same canonical-env pattern as mvp (scripts/mvp.env.canonical).

PUBLIC_URL=https://floom.dev
BETTER_AUTH_URL=https://floom.dev
NODE_ENV=production
DATA_DIR=/data
PORT=3000
DEPLOY_ENABLED=false

# Secrets (placeholders — passthrough from live container)
OPENAI_API_KEY=${OPENAI_API_KEY}
GEMINI_API_KEY=${GEMINI_API_KEY}
RESEND_API_KEY=${RESEND_API_KEY}
RESEND_FROM=Floom <noreply@send.floom.dev>
BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET}
GOOGLE_OAUTH_CLIENT_ID=${GOOGLE_OAUTH_CLIENT_ID}
GOOGLE_OAUTH_CLIENT_SECRET=${GOOGLE_OAUTH_CLIENT_SECRET}
# GitHub OAuth — Federico's app "Floom" (client id Ov23libh77VFQR1g6eKB).
# Callback URL configured: https://floom.dev/auth/callback/github
GITHUB_OAUTH_CLIENT_ID=Ov23libh77VFQR1g6eKB
GITHUB_OAUTH_CLIENT_SECRET=${GITHUB_OAUTH_CLIENT_SECRET}
FEEDBACK_GITHUB_TOKEN=${FEEDBACK_GITHUB_TOKEN}
FEEDBACK_GITHUB_REPO=floomhq/floom

# Models + runner
PARSER_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-small
RUNNER_TIMEOUT=300000
RUNNER_MEMORY=512m
RUNNER_CPUS=1
RUNNER_NETWORK=bridge
BUILD_TIMEOUT=600000

# --- error reporting (server) — Sentry DSN is public-by-design ---
SENTRY_SERVER_DSN=https://0c640f4db88a428519f9868f8ff5f124@o4511300722229248.ingest.us.sentry.io/4511300733108224
SENTRY_DSN=https://0c640f4db88a428519f9868f8ff5f124@o4511300722229248.ingest.us.sentry.io/4511300733108224
SENTRY_ENVIRONMENT=production

# --- analytics — PostHog US cloud, project ID 395246 (write-only key) ---
POSTHOG_PROJECT_API_KEY=phc_xjxQHBvGSUu7VLjcZyR2YSDAGeJuh4Y5rzyT7QjLPNSr
POSTHOG_HOST=https://us.i.posthog.com

# Floom flags
FLOOM_CLOUD_MODE=1
# Launch hardening: Docker-image publishing and bundled Docker seed apps stay
# disabled until the Docker runtime path has a separate isolation pass.
FLOOM_ENABLE_DOCKER_PUBLISH=false
FLOOM_SEED_APPS=false
FLOOM_APPS_CONFIG=/apps/catalog/apps.yaml
FLOOM_FILE_INPUTS_DIR=/floom-file-inputs
FLOOM_FILE_INPUTS_HOST_DIR=/opt/floom-preview-file-inputs
FLOOM_TRUSTED_PROXY_CIDRS=172.16.0.0/12

# Launch-week sidecars are mvp/preview-only; prod stays minimal.
# (FLOOM_LAUNCH_WEEK_APPS intentionally unset.)
